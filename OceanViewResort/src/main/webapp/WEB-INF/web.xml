<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Ocean View Resort – Room Reservation System</display-name>
  <description>Online Room Reservation System for Ocean View Resort, Galle</description>

  <!-- ── Welcome file ─────────────────────────────────────────────────── -->
  <welcome-file-list>
    <welcome-file>login</welcome-file>
  </welcome-file-list>

  <!-- ── Session timeout: 30 minutes ──────────────────────────────────── -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <!-- ── Error pages ───────────────────────────────────────────────────── -->
  <error-page>
    <error-code>404</error-code>
    <location>/jsp/error404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/jsp/error500.jsp</location>
  </error-page>

  <!-- ── Servlet mappings are handled via @WebServlet annotations ──────── -->
  <!-- ── (LoginServlet, LogoutServlet, DashboardServlet, etc.)      ──── -->

</web-app>
